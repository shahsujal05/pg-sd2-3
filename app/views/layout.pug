html
    head
        title #{title}
        style.
            body {
                font-family: Arial, sans-serif;
                margin: 40px;
                background: #f9f9f9;
                color: #333;
            }
            table {
                border-collapse: collapse;
                width: 100%;
                background: #fff;
            }
            th, td {
                padding: 10px 16px;
                text-align: left;
                border: 1px solid #ddd;
            }
            th {
                background-color: #1F3864;
                color: white;
            }
            tr:nth-child(even) { background-color: #f2f2f2; }
            a { color: #1F3864; text-decoration: none; }
            a:hover { text-decoration: underline; }
            h1 { color: #1F3864; border-bottom: 2px solid #2E75B6; padding-bottom: 8px; }
            h2 { color: #2E4A7A; }
    body
        block content
